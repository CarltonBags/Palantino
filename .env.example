POSTGRES_DB=civic_graph
POSTGRES_USER=civic
POSTGRES_PASSWORD=civic
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Cloud Postgres (Supabase / Neon / RDS): set DATABASE_URL to override the fields
# above. Needs PostGIS + pg_trgm + uuid-ossp enabled (Supabase/Neon all support).
# DATABASE_URL=postgresql://user:pass@host:5432/postgres
# Behind a transaction pooler (Supabase port 6543, Neon pooled, PgBouncer) set:
# DB_STATEMENT_CACHE_SIZE=0

# Dortmund Open Data Portal (no auth required but include for rate-limit contact)
OPENDATA_DORTMUND_BASE_URL=https://open-data.dortmund.de/api/explore/v2.1

# OParl: Dortmund uses somacos Session via OWL-IT.
# SessionNet UI: https://sessionnet.owl-it.de/dortmund/bi/
# OParl interface DISABLED in production (security decision, confirmed Oct 2024 via FragDenStaat).
# Leave blank until Dortmund re-enables it.
# OPARL_ENDPOINT_URL=

# Overpass API
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Bright Sky (DWD weather)
BRIGHTSKY_API_URL=https://api.brightsky.dev

# Vergabe.NRW tenders
VERGABE_NRW_BASE_URL=https://www.vergabe.nrw.de

# Claude API (reasoning layer)
ANTHROPIC_API_KEY=

# OpenAI API (embeddings / semantic layer)
OPENAI_API_KEY=

# Bot identity (honest identification per legal rules)
BOT_USER_AGENT=civic-graph/0.1 (research; kevin@byzerolab.de)

# Prefect
PREFECT_API_URL=http://localhost:4200/api
